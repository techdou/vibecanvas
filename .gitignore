coverage/
*.lcov

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor 配置目录（不上传）
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# VibeCanvas 运行时数据（用户项目本地生成，不属于源码）
.vibecanvas/

# ZCode 本地工作目录（plan / session 产物）
.zcode/

# Remotion / 第三方 MCP 本地数据
.data/

# 环境变量与密钥（只有模板可以提交）
.env
.env.local
.env.*.local
*.env
!*.env.example
!.env.example

# 配置文件可能含 API Key（只有 example 可提交）
config.json
!**/config.example.json
!**/*.example.json

# 临时文件与缓存
*.tmp
*.bak
*.cache
tmp/
.temp/

# 打包产物
*.zip
*.tar.gz
*.tgz

# 锁文件（保留 package-lock.json）
yarn.lock
pnpm-lock.yaml
