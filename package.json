{
  "name": "vibecanvas",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Agent-native infinite canvas and typed visual workflow studio for text-to-image and image-to-image creation.",
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c auto \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1 --port 5173\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "npm run typecheck && tsup && vite build",
    "start": "node dist/node/server.js",
    "mcp": "node dist/node/mcp.js",
    "cli": "node dist/node/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "quality": "npm run typecheck && npm test && npm run build && npm run probe:mcp",
    "doctor": "tsx scripts/doctor.ts",
    "install:skills": "tsx scripts/install-skills.ts",
    "package:release": "tsx scripts/package-release.ts",
    "probe:mcp": "tsx scripts/probe-mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.17.18",
    "@xyflow/react": "^12.11.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.4",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "archiver": "^8.0.0",
    "concurrently": "^9.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
