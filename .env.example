# VibeCanvas v2 uses one shared config file for Web, CLI, and MCP.
# Environment variables below are optional overrides and are useful for CI or temporary testing.

# User project whose canvas/database should be opened.
VIBECANVAS_PROJECT_DIR=/absolute/path/to/your/project

# Optional explicit shared config path.
# Linux/macOS default: ~/.config/vibecanvas/config.json
# Windows default: %APPDATA%\VibeCanvas\config.json
# VIBECANVAS_CONFIG_FILE=/absolute/path/to/config.json

VIBECANVAS_HOST=127.0.0.1
VIBECANVAS_PORT=43120
VIBECANVAS_CONCURRENCY=1
VIBECANVAS_LEASE_SECONDS=30

# Active OpenAI-compatible Image 2 relay overrides.
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://your-relay.example/v1
IMAGE_API_MODEL=gpt-image-2
IMAGE_API_GENERATE_PATH=/images/generations
IMAGE_API_EDIT_PATH=/images/edits
IMAGE_API_TIMEOUT_MS=180000
IMAGE_API_MAX_RETRIES=3
IMAGE_API_EDIT_IMAGE_FIELD=image[]
IMAGE_API_OUTPUT_FORMAT=png

# JSON objects. Useful for channel IDs, relay signatures, and protected output URLs.
IMAGE_API_HEADERS_JSON={}
IMAGE_API_DOWNLOAD_HEADERS_JSON={}
IMAGE_API_EXTRA_JSON={}

# Keep false unless the relay intentionally returns localhost/private-network image URLs.
IMAGE_API_ALLOW_PRIVATE_URLS=false

# ---------------------------------------------------------------------------
# Pluggable LLM providers for the Prompt Architect and Vision Review nodes.
# Two independent profiles (architect / reviewer) so the reviewer can target a
# vision-capable model while the architect uses a cheaper text model.
#
# Provider kinds:
#   - openai-chat       Any OpenAI-compatible /chat/completions endpoint.
#                       Works with OpenAI, Doubao/Ark, GLM, OpenRouter, ollama, vLLM.
#   - opencode-session  Legacy opencode serve API. Still supported for users who
#                       run `opencode serve` and want VibeCanvas to talk to it.
#   - fallback          Deterministic local heuristic. No external calls. The
#                       default; everything works without configuring an LLM.
#
# When provider = opencode-session, the legacy OPENCODE_* vars below also feed
# this profile. When provider = openai-chat, use VIBECANVAS_LLM_<ROLE>_*.
# ---------------------------------------------------------------------------

# Architect profile: composes a structured PromptSpec from the creative brief.
# Example: Doubao (Ark) chat model.
# VIBECANVAS_LLM_ARCHITECT_PROVIDER=openai-chat
# VIBECANVAS_LLM_ARCHITECT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VIBECANVAS_LLM_ARCHITECT_API_KEY=
# VIBECANVAS_LLM_ARCHITECT_MODEL=doubao-pro-32k-241226
# VIBECANVAS_LLM_ARCHITECT_HEADERS_JSON={}

# Reviewer profile: compares candidate images and returns an EvaluationReport.
# Needs a vision-capable model. Example: GPT-4o via OpenAI.
# VIBECANVAS_LLM_REVIEWER_PROVIDER=openai-chat
# VIBECANVAS_LLM_REVIEWER_BASE_URL=https://api.openai.com/v1
# VIBECANVAS_LLM_REVIEWER_API_KEY=
# VIBECANVAS_LLM_REVIEWER_MODEL=gpt-4o
# VIBECANVAS_LLM_REVIEWER_HEADERS_JSON={}

# Legacy OpenCode server variables. Only consumed when an LLM profile has
# provider = opencode-session. Kept for backward compatibility.
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_SESSION_ID=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
